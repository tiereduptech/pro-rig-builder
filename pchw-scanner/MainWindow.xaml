<Window x:Class="ProRigScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pro Rig Builder — System Scanner"
        Width="760" Height="920"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg"       Color="#0F0F14"/>
        <SolidColorBrush x:Key="Bg2"      Color="#16161E"/>
        <SolidColorBrush x:Key="Bg3"      Color="#1E1E28"/>
        <SolidColorBrush x:Key="Border"   Color="#2A2A36"/>
        <SolidColorBrush x:Key="Text"     Color="#F5F5F7"/>
        <SolidColorBrush x:Key="Dim"      Color="#B8B8C8"/>
        <SolidColorBrush x:Key="Mute"     Color="#8A8A98"/>
        <SolidColorBrush x:Key="Accent"   Color="#FF8A3D"/>
        <SolidColorBrush x:Key="Amber"    Color="#FFB020"/>
        <SolidColorBrush x:Key="Green"    Color="#4ADE80"/>

        <LinearGradientBrush x:Key="TowerGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF6B35" Offset="0"/>
            <GradientStop Color="#F5A623" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="#1A1A20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#FF9A4D"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="border" Property="Background" Value="#EF7A2D"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OptionCard" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Bg3}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter TargetName="border" Property="Background" Value="#232330"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Dim}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#33FF4444"/>
                                <Setter Property="Foreground" Value="#FF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OrangeSlider" TargetType="Slider">
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="6" CornerRadius="3" Background="{StaticResource Bg3}" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Height="6" CornerRadius="3,0,0,3" Background="{StaticResource Accent}" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate><Border Background="Transparent"/></ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Grid>
                                                    <Ellipse Width="22" Height="22" Fill="{StaticResource Accent}" Stroke="#FFB37D" StrokeThickness="2"/>
                                                    <Ellipse Width="8" Height="8" Fill="White" Opacity="0.3"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Background="{StaticResource Bg}" BorderBrush="{StaticResource Border}" BorderThickness="1">
        <Border.Effect><DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.6" Color="Black"/></Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR with real TowerLogo ═══ -->
            <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown" Padding="20,12,8,8">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- TowerLogo SVG ported to XAML shapes. Frame = 30px wide, 36px tall -->
                        <Canvas Width="30" Height="36" Margin="0,0,10,0">
                            <Rectangle Canvas.Left="0" Canvas.Top="0" Width="30" Height="36" RadiusX="4" RadiusY="4" Stroke="{StaticResource Accent}" StrokeThickness="1" Opacity="0.3"/>
                            <Rectangle Canvas.Left="4" Canvas.Top="4" Width="22" Height="6" RadiusX="2" RadiusY="2" Fill="{StaticResource TowerGradient}"/>
                            <Rectangle Canvas.Left="4" Canvas.Top="12" Width="22" Height="4" RadiusX="1.2" RadiusY="1.2" Fill="{StaticResource Accent}"/>
                            <Rectangle Canvas.Left="4" Canvas.Top="19" Width="22" Height="3" RadiusX="1" RadiusY="1" Fill="{StaticResource Accent}" Opacity="0.7"/>
                            <Rectangle Canvas.Left="8" Canvas.Top="25" Width="14" Height="4" RadiusX="1.2" RadiusY="1.2" Fill="{StaticResource Accent}" Opacity="0.85"/>
                            <Rectangle Canvas.Left="4" Canvas.Top="31" Width="22" Height="2.5" RadiusX="1" RadiusY="1" Fill="{StaticResource Accent}" Opacity="0.4"/>
                        </Canvas>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Pro Rig" FontWeight="Bold" FontSize="15" Foreground="{StaticResource Text}" LineHeight="16"/>
                            <TextBlock Text="BUILDER" FontWeight="Medium" FontSize="9" Foreground="{StaticResource Dim}" Typography.StylisticSet1="True"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Style="{StaticResource CloseButton}" Content="✕" Click="CloseButton_Click" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="32,8,32,16">

                <!-- ── INPUT VIEW ── -->
                <StackPanel x:Name="InputView" Visibility="Visible">
                    <TextBlock Text="System Scanner" FontSize="30" FontWeight="Bold" Foreground="{StaticResource Text}" Margin="0,4,0,2"/>
                    <TextBlock Text="Scan your PC and get upgrade recommendations tailored to your budget." Foreground="{StaticResource Dim}" FontSize="13" Margin="0,0,0,24"/>

                    <!-- Budget section -->
                    <Border Background="{StaticResource Bg2}" CornerRadius="12" Padding="22,18" Margin="0,0,0,14">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,12">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="UPGRADE BUDGET" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Dim}"/>
                                    <TextBlock Text="Maximum you want to spend total" FontSize="12" Foreground="{StaticResource Dim}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="BudgetLabel" Text="$1,000" DockPanel.Dock="Right" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Accent}" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Slider x:Name="BudgetSlider" Style="{StaticResource OrangeSlider}" Value="50" ValueChanged="BudgetSlider_ValueChanged"/>
                            <DockPanel Margin="0,6,0,0">
                                <TextBlock Text="$300" FontSize="10" Foreground="{StaticResource Mute}" FontFamily="Consolas"/>
                                <TextBlock Text="$8,000" FontSize="10" Foreground="{StaticResource Mute}" FontFamily="Consolas" HorizontalAlignment="Right"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Storage — Step 1: yes/no -->
                    <Border Background="{StaticResource Bg2}" CornerRadius="12" Padding="22,18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="ADD EXTRA STORAGE?" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Dim}"/>
                            <TextBlock Text="Optional — add another drive to your build" FontSize="12" Foreground="{StaticResource Dim}" Margin="0,2,0,12"/>
                            <UniformGrid Columns="2" Height="68">
                                <Button x:Name="StorageNoBtn" Tag="no" Style="{StaticResource OptionCard}" Click="StorageYesNo_Click">
                                    <StackPanel>
                                        <TextBlock Text="No, skip" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="keep current drives only" FontSize="10" Foreground="{StaticResource Mute}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="StorageYesBtn" Tag="yes" Style="{StaticResource OptionCard}" Click="StorageYesNo_Click">
                                    <StackPanel>
                                        <TextBlock Text="Yes, add" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="pick type and size below" FontSize="10" Foreground="{StaticResource Mute}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </UniformGrid>

                            <!-- Step 2: HDD vs SSD (hidden until Yes) -->
                            <StackPanel x:Name="StorageTypePanel" Visibility="Collapsed" Margin="0,14,0,0">
                                <TextBlock Text="DRIVE TYPE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Dim}" Margin="0,0,0,8"/>
                                <UniformGrid Columns="2" Height="68">
                                    <Button x:Name="HddBtn" Tag="HDD" Style="{StaticResource OptionCard}" Click="StorageType_Click">
                                        <StackPanel>
                                            <TextBlock Text="HDD" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="cheaper · more space" FontSize="9" Foreground="{StaticResource Mute}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="SsdBtn" Tag="SSD" Style="{StaticResource OptionCard}" Click="StorageType_Click">
                                        <StackPanel>
                                            <TextBlock Text="SSD" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="faster · better performance" FontSize="9" Foreground="{StaticResource Mute}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>

                            <!-- Step 3: size (hidden until type chosen) -->
                            <StackPanel x:Name="StorageSizePanel" Visibility="Collapsed" Margin="0,14,0,0">
                                <TextBlock Text="SIZE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Dim}" Margin="0,0,0,8"/>
                                <UniformGrid x:Name="StorageSizes" Columns="4" Height="64">
                                    <!-- Populated dynamically based on type: SSD = 500GB/1TB/2TB/4TB; HDD = 1TB/2TB/4TB/8TB -->
                                </UniformGrid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Content="⚡  Scan My PC" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch" Height="52" Margin="0,4,0,0" Click="ScanButton_Click"/>
                </StackPanel>

                <!-- ── SCAN VIEW ── -->
                <StackPanel x:Name="ScanView" Visibility="Collapsed">
                    <TextBlock Text="Scanning Your System" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Text}" Margin="0,4,0,4"/>
                    <TextBlock Text="Analyzing your hardware configuration..." FontSize="13" Foreground="{StaticResource Dim}" Margin="0,0,0,24"/>
                    <Border Background="{StaticResource Bg2}" CornerRadius="12" Padding="24">
                        <StackPanel x:Name="ScanSteps"/>
                    </Border>
                </StackPanel>

                <!-- ── DONE VIEW ── -->
                <StackPanel x:Name="DoneView" Visibility="Collapsed">
                    <TextBlock Text="Scan Complete" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Green}" Margin="0,4,0,4"/>
                    <TextBlock Text="Opening your personalized upgrade page..." FontSize="13" Foreground="{StaticResource Dim}" Margin="0,0,0,20"/>
                    <Border Background="{StaticResource Bg2}" CornerRadius="12" Padding="24">
                        <StackPanel x:Name="SummaryPanel"/>
                    </Border>
                    <Button x:Name="OpenBrowserButton" Content="🚀  Open My Upgrade Page" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch" Height="48" Margin="0,18,0,0" Click="OpenBrowser_Click"/>
                </StackPanel>
            </Grid>

            <!-- ═══ FOOTER ═══ -->
            <Border Grid.Row="2" Background="#0A0A10" CornerRadius="0,0,16,16" Padding="20,12" BorderThickness="0,1,0,0" BorderBrush="{StaticResource Border}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Image Source="assets/tiereduptech-logo-trans.png" Width="28" Height="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="10" Foreground="{StaticResource Dim}">
                                <Run Text="Created by " /><Run Text="TieredUp Tech, Inc." FontWeight="Bold" Foreground="{StaticResource Text}"/>
                            </TextBlock>
                            <TextBlock FontSize="9" Foreground="{StaticResource Mute}" FontFamily="Consolas">
                                <Run Text="tiereduptech.com"/><Run Text=" · "/><Run Text="support@tiereduptech.com"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="9" Foreground="{StaticResource Mute}" FontFamily="Consolas" Text="v2.0"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
